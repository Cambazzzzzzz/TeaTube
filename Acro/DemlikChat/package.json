{
  "name": "demlikchat",
  "version": "1.0.0",
  "description": "Modern mesajlaşma uygulaması",
  "main": "electron.js",
  "scripts": {
    "start": "electron .",
    "dev": "nodemon server.js",
    "build": "electron-builder"
  },
  "build": {
    "appId": "com.demlik.chat",
    "productName": "DemlikChat",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": "nsis",
      "icon": "assets/icon.ico"
    }
  },
  "dependencies": {
    "express": "^4.18.2",
    "socket.io": "^4.6.1",
    "socket.io-client": "^4.6.1",
    "better-sqlite3": "^9.2.2",
    "bcrypt": "^5.1.1",
    "multer": "^1.4.5-lts.1",
    "simple-peer": "^9.11.1"
  },
  "devDependencies": {
    "electron": "^28.1.0",
    "electron-builder": "^24.9.1",
    "nodemon": "^3.0.2"
  }
}
