{
  "name": "teatube",
  "version": "1.0.0",
  "description": "TeaTube - Video Paylaşım Platformu",
  "main": "electron.js",
  "scripts": {
    "start": "node server.js",
    "electron": "electron .",
    "dev": "nodemon server.js",
    "build": "electron-builder"
  },
  "keywords": ["video", "platform", "teatube"],
  "author": "TeaTube",
  "license": "MIT",
  "dependencies": {
    "express": "^4.18.2",
    "better-sqlite3": "^9.2.2",
    "bcrypt": "^5.1.1",
    "multer": "^1.4.5-lts.1",
    "cloudinary": "^1.41.0",
    "cors": "^2.8.5"
  },
  "devDependencies": {
    "electron": "^28.1.0",
    "electron-builder": "^24.9.1",
    "nodemon": "^3.0.2"
  },
  "build": {
    "appId": "com.teatube.app",
    "productName": "TeaTube",
    "directories": {
      "output": "dist"
    },
    "files": [
      "**/*",
      "!data/teatube.db"
    ],
    "win": {
      "target": "nsis",
      "icon": "assets/icon.ico"
    }
  }
}
